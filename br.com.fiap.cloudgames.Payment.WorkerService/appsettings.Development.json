{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "RabbitMQ": {
    "URI": "amqp://admin:admin123@localhost:5672/",
    "OrderPaymentRequestedEvent": {
      "Exchange": "fcg",
      "RoutingKey": "order.payment_request"
    },
    "PaymentFailedEvent": {
      "Exchange": "fcg",
      "RoutingKey": "payment.failed"
    },
    "PaymentProcessedEvent": {
      "Exchange": "fcg",
      "RoutingKey": "payment.processed"
    }
  }
}
